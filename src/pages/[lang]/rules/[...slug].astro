---
import { getCollection, render } from 'astro:content';
import Rulebook from '../../../layouts/Rulebook.astro';
import { splitId, idToSlug, type Lang } from '../../../lib/tree';

export async function getStaticPaths() {
  const entries = await getCollection('rules');
  return entries.map((entry) => {
    const { lang, id } = splitId(entry.id);
    return {
      params: { lang, slug: idToSlug(id) },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(entry);
---

<Rulebook pageTitle={entry.data.title} section="rules" lang={lang}>
  <Content />
</Rulebook>
