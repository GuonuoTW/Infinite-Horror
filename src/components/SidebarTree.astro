---
import type { TreeNode } from '../lib/tree';
import { pathToHref } from '../lib/tree';

interface Props {
  node: TreeNode;
  currentPath: string;
}

const { node, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;

const href = pathToHref(node.path);
const normalize = (p: string) => p.replace(/\/+$/, '') || '/';
const isActive = normalize(href) === normalize(currentPath);
// Open this folder if the current page lives inside it.
const containsActive =
  node.isFolder && normalize(currentPath).startsWith(normalize(href));
---

{
  node.isFolder ? (
    <div class="folder">
      <div class:list={['folder-header', { active: isActive }]}>
        <div class="folder-toggle">{containsActive ? '−' : '+'}</div>
        <img
          class="folder-icon"
          src={`${base}icons/${containsActive ? 'folder-open' : 'folder-closed'}.png`}
          alt="folder"
        />
        <a class="folder-name" href={href}>
          {node.title}
        </a>
      </div>
      <div
        class:list={['folder-content', { open: containsActive }]}
        data-folder={node.path}
      >
        {node.children.map((child) => (
          <Astro.self node={child} currentPath={currentPath} />
        ))}
      </div>
    </div>
  ) : (
    <a class:list={['file-item', { active: isActive }]} href={href}>
      <img class="file-icon" src={`${base}icons/file.png`} alt="file" />
      <span>{node.title}</span>
    </a>
  )
}
